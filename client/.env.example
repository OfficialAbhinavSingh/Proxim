# WebSocket server address (must match PORT in server/.env)
VITE_WS_URL=ws://localhost:3001

# REST API base URL for transcription fallback (must match server PORT, default 3001)
VITE_API_URL=http://localhost:3001

# Same origin as API for /assets/rpm/* avatar proxy (default http://localhost:3001)
# VITE_HTTP_SERVER_URL=http://localhost:3001

# Set to false if the server cannot reach models.readyplayer.me (502) but the browser can load RPM directly.
# VITE_RPM_USE_PROXY=false

# In dev, Ready Player Me GLBs load via Vite `/__rpm` → models.readyplayer.me (helps when the browser cannot resolve RPM DNS).
# Set to false to use only the API server proxy at VITE_HTTP_SERVER_URL instead.
# VITE_RPM_USE_VITE_DEV_PROXY=false

# ONNX Runtime WASM base URL is derived at build time from the installed onnxruntime-web version (see vite.config.ts).

# Set to true to always use server Whisper + silence detection (recommended on VPN / when Web Speech fails)
# VITE_FORCE_SERVER_STT=true

# Optional: override the fallback GLB used for local /avatars/*.glb paths.
# Personas now use HTTPS Ready Player Me URLs directly so this is only needed
# if you want to swap the demo model loaded when a local file is missing.
# VITE_DEFAULT_AVATAR_GLB=https://models.readyplayer.me/your-model.glb?morphTargets=ARKit,Oculus%20Visemes
