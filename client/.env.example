# WebSocket server address (must match PORT in server/.env)
VITE_WS_URL=ws://localhost:3001

# REST API base URL for transcription fallback
VITE_API_URL=http://localhost:3001

# Optional: override the fallback GLB used for local /avatars/*.glb paths.
# Personas now use HTTPS Ready Player Me URLs directly so this is only needed
# if you want to swap the demo model loaded when a local file is missing.
# VITE_DEFAULT_AVATAR_GLB=https://models.readyplayer.me/your-model.glb?morphTargets=ARKit,Oculus%20Visemes
