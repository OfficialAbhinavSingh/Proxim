FROM node:20-bookworm-slim AS build
WORKDIR /app
COPY server/package.json ./
RUN npm install
COPY server/tsconfig.json ./
COPY server/scripts ./scripts
COPY server/src ./src
RUN npm run build

FROM node:20-bookworm-slim
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3001
ENV AVATAR_PUBLIC_DIR=/app/public/avatars
COPY server/package.json ./
RUN npm install --omit=dev
COPY --from=build /app/dist ./dist
COPY server/src/config/personas.json ./dist/config/personas.json
COPY client/public/avatars ./public/avatars
ENV PERSONAS_PATH=/app/dist/config/personas.json
EXPOSE 3001
CMD ["node", "dist/index.js"]
