PORT=3001

# === LLM (pick one) ===
# OPTION A — Groq (FREE, recommended): https://console.groq.com/keys
# Uses llama-3.3-70b-versatile — fast, high quality, 14,400 req/day free
GROQ_API_KEY=

# OPTION B — Anthropic Claude (paid): https://console.anthropic.com/settings/keys
# If GROQ_API_KEY is set, this is ignored.
ANTHROPIC_API_KEY=

# Required for audio – ElevenLabs TTS
ELEVENLABS_API_KEY=
# Default voice when a persona's voiceId is missing / not set in personas.json
# Pre-configured voices in personas.json: 21m00Tcm4TlvDq8ikWAM (Rachel),
#   EXAVITQu4vr4xnSDxMaL (Bella), ErXwobaYiN019PkySvjV (Antoni)
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Rhubarb Lip Sync binary path
# Docker: /usr/local/bin/rhubarb  (auto-installed in Dockerfile.server)
# Linux/macOS dev: rhubarb  (if on PATH) or /usr/local/bin/rhubarb
# Windows dev: C:\rhubarb\rhubarb.exe  — download from:
#   https://github.com/DanielSWolf/rhubarb-lip-sync/releases
# NOTE: If Rhubarb is not installed the server uses a phoneme-based fallback
#       for lip sync — all other features work normally.
RHUBARB_PATH=rhubarb

# Optional: OpenAI key enables MediaRecorder → Whisper transcription fallback
# (used when Web Speech API is unavailable, e.g. Firefox)
OPENAI_API_KEY=

# Optional: override the default personas file location
# PERSONAS_PATH=/absolute/path/to/personas.json
