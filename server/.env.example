PORT=3001

LLM_PROVIDER=auto
# Valid values: auto, groq, anthropic, openai.
# auto preserves the current order: Groq -> Anthropic -> OpenAI.

# === LLM (pick one) ===
# OPTION A — Groq (FREE, recommended): https://console.groq.com/keys
# Uses llama-3.3-70b-versatile — fast, high quality, 14,400 req/day free
# Same key also enables: Groq TTS (persona voice) and Groq Whisper on POST /session/transcribe
# when Web Speech fails (VPN/proxy, Firefox, etc.). Minimum practical setup: GROQ_API_KEY only.
GROQ_API_KEY=

# OPTION B — Anthropic Claude (paid): https://console.anthropic.com/settings/keys
# In auto mode, this is used after Groq. Set LLM_PROVIDER=anthropic to force it.
ANTHROPIC_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1

# Optional — ElevenLabs TTS (best lip-sync via audio alignment). If unset, persona voice uses Groq TTS (needs GROQ_API_KEY).
# Remove or leave empty if your key is invalid — otherwise every sentence still tries ElevenLabs before falling back.
ELEVENLABS_API_KEY=
# Default voice when a persona's voiceId is missing / not set in personas.json
# Pre-configured voices in personas.json: 21m00Tcm4TlvDq8ikWAM (Rachel),
#   EXAVITQu4vr4xnSDxMaL (Bella), ErXwobaYiN019PkySvjV (Antoni)
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Optional: OpenAI GPT-4 family dialogue and Whisper fallback.
# Set LLM_PROVIDER=openai to force OpenAI for dialogue.
OPENAI_API_KEY=

# STT Model — Groq Whisper variant used by POST /session/transcribe
# whisper-large-v3-turbo is the recommended default (faster, no hallucinations with temperature=0)
GROQ_STT_MODEL=whisper-large-v3-turbo

# Optional: override the default personas file location
# PERSONAS_PATH=/absolute/path/to/personas.json
